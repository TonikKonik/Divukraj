generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  createdAt DateTime @default(now())

  hostedGames Game[]       @relation("GameHost")
  players     GamePlayer[]
}

model Game {
  id         String     @id @default(cuid())
  name       String
  status     GameStatus @default(LOBBY)
  maxPlayers Int        @default(4)
  createdAt  DateTime   @default(now())

  host      User         @relation("GameHost", fields: [hostId], references: [id])
  hostId    String
  players   GamePlayer[]
  gameState GameState?
}

model GamePlayer {
  id       String      @id @default(cuid())
  color    PlayerColor
  joinedAt DateTime    @default(now())

  game   Game   @relation(fields: [gameId], references: [id])
  gameId String
  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@unique([gameId, userId])
  @@unique([gameId, color])
}

model GameState {
  id               String   @id @default(cuid())
  gameId           String   @unique
  game             Game     @relation(fields: [gameId], references: [id])
  season           Season   @default(SPRING)
  currentPlayerIdx Int      @default(0)
  meadow           String[]
  deck             String[]
  discard          String[]

  playerStates PlayerState[]
  workers      WorkerPlacement[]
}

model PlayerState {
  id          String    @id @default(cuid())
  gameStateId String
  gameState   GameState @relation(fields: [gameStateId], references: [id])
  userId      String
  twigs       Int       @default(0)
  resin       Int       @default(0)
  pebbles     Int       @default(0)
  berries     Int       @default(0)
  hand        String[]
  city        String[]

  @@unique([gameStateId, userId])
}

model WorkerPlacement {
  id          String    @id @default(cuid())
  gameStateId String
  gameState   GameState @relation(fields: [gameStateId], references: [id])
  userId      String
  location    String
  season      Season    @default(SPRING)
}

enum GameStatus {
  LOBBY
  PLAYING
  FINISHED
}

enum PlayerColor {
  RED
  BLUE
  GREEN
  ORANGE
}

enum Season {
  SPRING
  SUMMER
  AUTUMN
  WINTER
}
